# Django
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=newspass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis/Celery
REDIS_URL=redis://localhost:6379/0

# Migration Feature Flag
# false = использовать legacy Perl парсер (Phase 1)
# true = использовать Python парсер (Phase 3)
USE_PYTHON_PARSER=false